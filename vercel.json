{
  "version": 2,
  "name": "unrlvl-context",
  "builds": [{ "src": "**/*", "use": "@vercel/static" }],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ]
}
